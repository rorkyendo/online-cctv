* text=auto eol=lf

# Pastikan file kritis selalu LF — tidak boleh CRLF di Linux container
Dockerfile       text eol=lf
*.dockerfile     text eol=lf
*.sh             text eol=lf
*.py             text eol=lf
*.conf           text eol=lf
*.ini            text eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
